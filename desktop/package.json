{
  "name": "wxtools-desktop",
  "version": "0.6.0",
  "description": "wxtools Desktop — Local WeChat data workstation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir",
    "build:py": "python scripts/build.py --skip-installer",
    "build:all": "python scripts/build.py"
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.wxtools.desktop",
    "productName": "wxtools",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "wxtools"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "extraResources": [
      {
        "from": "build/pyinstaller-output/wxtools-backend",
        "to": "wxtools-backend",
        "filter": ["**/*"]
      },
      {
        "from": "../web/dist",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ]
  }
}
